<?xml version="1.0" encoding="UTF-8"?>
<!--
  REFERENCE template (human-readable). The authoritative plist is generated at
  runtime by audio_daemon/platforms/macos.py with the correct interpreter/binary
  path and per-user log paths. Tokens below: __PROGRAM__, __HOME__.
  Installed to: ~/Library/LaunchAgents/com.teamsigma.audiodaemon.plist
-->
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>com.teamsigma.audiodaemon</string>

  <key>ProgramArguments</key>
  <array>
    <string>__PROGRAM__</string>
    <string>--mode=daemon</string>
  </array>

  <key>RunAtLoad</key>
  <true/>

  <key>KeepAlive</key>
  <dict>
    <key>SuccessfulExit</key>
    <false/>
    <key>Crashed</key>
    <true/>
  </dict>

  <key>ThrottleInterval</key>
  <integer>5</integer>

  <!-- Interactive => runs in the GUI session so the mic/TCC prompt can appear. -->
  <key>ProcessType</key>
  <string>Interactive</string>

  <key>StandardOutPath</key>
  <string>__HOME__/Library/Logs/teamsigma-audiodaemon.log</string>
  <key>StandardErrorPath</key>
  <string>__HOME__/Library/Logs/teamsigma-audiodaemon.error.log</string>

  <key>EnvironmentVariables</key>
  <dict>
    <key>PATH</key>
    <string>/usr/local/bin:/usr/bin:/bin:/usr/sbin:/sbin</string>
    <key>AUDIO_DAEMON_PORT</key>
    <string>8770</string>
  </dict>
</dict>
</plist>
