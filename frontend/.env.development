# Local dev. Leave API_URL empty to use Vite's /api proxy (see vite.config.js).
# Set VITE_USE_MOCK=true to run fully offline against the in-memory mock.
VITE_API_URL=
VITE_USE_MOCK=false
VITE_DEFAULT_USER_ID=1
# AudioDaemon (local native audio service) — dedicated port, not :8080.
VITE_AUDIO_DAEMON_URL=http://localhost:8770
